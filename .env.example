# Supabase — Project Settings → API Keys (or top bar → Connect)
# NOT the dashboard URL — use Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Use the PUBLISHABLE key (sb_publishable_...) or legacy "anon" key — NOT secret/service_role
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# Postgres — Supabase Connect → Transaction pooler, port 6543
# Recommended: discrete vars (password can contain special characters; use quotes)
DATABASE_HOST=aws-0-[region].pooler.supabase.com
DATABASE_PORT=6543
DATABASE_USER=postgres.[project-ref]
DATABASE_PASSWORD="your-database-password"
DATABASE_NAME=postgres

# Alternative: single URL (password must be URL-encoded if it has special chars)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
