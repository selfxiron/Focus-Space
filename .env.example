# Supabase — Project Settings → API Keys (or top bar → Connect)
# NOT the dashboard URL — use Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Use the PUBLISHABLE key (sb_publishable_...) or legacy "anon" key — NOT secret/service_role
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# Postgres — click "Connect" at top of project dashboard → ORMs / Drizzle / Transaction pooler (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
